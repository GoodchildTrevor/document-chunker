# -------------------------------------------------------
# document-chunker — environment variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Port exposed on the host
APP_PORT=8001

# URL of the external OCR / file-worker service.
# This service receives a PDF page (or image) and returns extracted text.
# Example: http://file-worker:9000/parse
FILE_WORKER_URL=http://file-worker:9000/parse

# Seconds allowed for LibreOffice .doc -> .docx conversion
LIBREOFFICE_TIMEOUT=60

# Default max tokens per chunk (can be overridden per-request via Form field)
CHUNK_SIZE=512

# Default sentence overlap between adjacent chunks
OVERLAP=1
